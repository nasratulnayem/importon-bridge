{
  "manifest_version": 3,
  "name": "Importon Bridge Extension",
  "short_name": "Importon Bridge",
  "version": "0.1.0",
  "description": "Product sync extension for WooCommerce store imports from supported supplier pages.",
  "permissions": ["storage", "scripting", "activeTab", "notifications"],
  "host_permissions": ["https://*.alibaba.com/*", "http://*.alibaba.com/*", "file:///*", "http://localhost/*", "http://127.0.0.1/*", "http://*/*", "https://*/*"],
  "background": { "service_worker": "src/background.js" },
  "action": {
    "default_title": "Importon Bridge Extension",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/import.png",
      "48": "src/import.png",
      "128": "src/import.png"
    }
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://*.alibaba.com/*", "http://*.alibaba.com/*", "file:///*"],
      "js": ["src/content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/wp-admin-bridge.js"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/import.png",
    "48": "src/import.png",
    "128": "src/import.png"
  }
}
